# Copy to inventory.ini and fill in real IPs from `terraform output`.
# NEVER commit inventory.ini — it contains node IPs.

[k3s_control]
control ansible_host=CONTROL_PUBLIC_IP ansible_user=ubuntu

[k3s_workers]
worker0 ansible_host=WORKER0_PUBLIC_IP ansible_user=ubuntu
worker1 ansible_host=WORKER1_PUBLIC_IP ansible_user=ubuntu

[all:vars]
ansible_python_interpreter=/usr/bin/python3
ansible_ssh_private_key_file=~/.ssh/your-keypair.pem
admin_allowed_cidr=YOUR_PUBLIC_IP/32
vpc_cidr=10.10.0.0/16
