.env
.env.*
!.env.example
*secret*.yaml
!manifests/taskapp/secret.yaml
!*secret*.example.yaml
*.pem
*.key
id_rsa*

# argo / helm local
charts/*.tgz

# os / editor
.DS_Store
*.swp
.idea/
.vscode/
