# Copy to terraform.tfvars and fill in real values.
# NEVER commit terraform.tfvars — it is in .gitignore.

aws_region   = "us-east-1"
cluster_name = "capstone-phoenix"

# VPC — 2 subnets in 2 AZs so workers land in different AZs
vpc_cidr            = "10.10.0.0/16"
public_subnet_cidrs = ["10.10.1.0/24", "10.10.2.0/24"]
availability_zones  = ["us-east-1a", "us-east-1b"]

# Compute
control_instance_type = "t3.small"
worker_instance_type  = "t3.small"
worker_count          = 2

# Auth — replace with your actual key pair name and your public IP
ssh_key_name     = "your-keypair-name"
ssh_allowed_cidr = "YOUR_PUBLIC_IP/32"

# Remote state (bootstrap using `terraform apply` in remote-state/ then set these)
# Example names — change to globally unique S3 bucket and a DynamoDB table name
state_bucket_name = "capstone-phoenix-terraform-state-<your-suffix>"
lock_table_name   = "capstone-phoenix-terraform-locks"
